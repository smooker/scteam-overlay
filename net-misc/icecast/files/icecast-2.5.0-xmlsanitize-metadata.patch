+/* Strip characters invalid in XML 1.0. Input/output UTF-8. Returns malloc string. */
+static char *xmlsanitize(const char *src) {
+    size_t i, j, len;
+    unsigned char c;
+    uint32_t cp;
+    int seq, ok, k;
+    char *dst;
+    if (!src) return NULL;
+    len = strlen(src);
+    dst = (char*)malloc(len + 1);
+    if (!dst) return NULL;
+    for (i = 0, j = 0; i < len; ) {
+        c = (unsigned char)src[i];
+        if      (c < 0x80)             { cp = c;        seq = 1; }
+        else if ((c & 0xE0) == 0xC0)   { cp = c & 0x1F; seq = 2; }
+        else if ((c & 0xF0) == 0xE0)   { cp = c & 0x0F; seq = 3; }
+        else if ((c & 0xF8) == 0xF0)   { cp = c & 0x07; seq = 4; }
+        else { i++; continue; }
+        ok = 1;
+        for (k = 1; k < seq && (i+(size_t)k) < len; k++) {
+            unsigned char cb = (unsigned char)src[i+k];
+            if ((cb & 0xC0) != 0x80) { ok = 0; break; }
+            cp = (cp << 6) | (cb & 0x3F);
+        }
+        if (!ok) { i++; continue; }
+        if (cp == 0x9 || cp == 0xA || cp == 0xD ||
+            (cp >= 0x20 && cp <= 0xD7FF) ||
+            (cp >= 0xE000 && cp <= 0xFFFD) ||
+            (cp >= 0x10000 && cp <= 0x10FFFF)) {
+            memcpy(dst+j, src+i, (size_t)seq);
+            j += (size_t)seq;
+        }
+        i += (size_t)seq;
+    }
+    dst[j] = '\0';
+    return dst;
+}
