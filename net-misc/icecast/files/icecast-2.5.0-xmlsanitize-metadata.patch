+    size_t i, j, len; unsigned char c; uint32_t cp; int seq, ok, k; char *dst;
+    if (!src) return NULL;
+    len = strlen(src); dst = (char*)malloc(len + 1); if (!dst) return NULL;
+    for (i = 0, j = 0; i < len; ) {
+        c = (unsigned char)src[i];
+        if      (c < 0x80)             { cp = c;        seq = 1; }
