#!/sbin/openrc-run
# OpenRC init script for xrdp-sesman

description="xrdp session manager"

command="/usr/sbin/xrdp-sesman"
command_args="--nodaemon"
command_background=true
pidfile="/run/xrdp/xrdp-sesman.pid"

depend() {
    need net xrdp
    after logger
}

start_pre() {
    checkpath -d -m 0755 -o root:root /run/xrdp
}
